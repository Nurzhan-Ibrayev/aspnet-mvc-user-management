@using Task4.ViewModels
@{
    ViewData["Title"] = "Home Page";
}

@model List<UsersViewModel>

<div class="container mt-4">
    
    <h2 class="mb-3">Users</h2>


    <form method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <button type="submit" asp-action="Block"
                    class="btn btn-warning"
                    data-bs-toggle="tooltip"
                    data-bs-placement="bottom"
                    title="Block selected users">
                Block
            </button>

            <button type="submit" asp-action="Unblock"
                    class="btn btn-link text-success"
                    data-bs-toggle="tooltip"
                    data-bs-placement="bottom"
                    title="Unblock selected users">
                <i class="fa-solid fa-unlock"></i>
            </button>

            <button type="submit" asp-action="Delete"
                    class="btn btn-link text-danger"
                    data-bs-toggle="tooltip"
                    data-bs-placement="bottom"
                    title="Delete selected users">
                <i class="fa-solid fa-trash"></i>
            </button>

            <button type="submit" asp-action="DeleteUnverified"
                    class="btn btn-link text-danger"
                    data-bs-toggle="tooltip"
                    data-bs-placement="bottom"
                    title="Delete all unverified users">
                <i class="fa-solid fa-user-xmark"></i>
            </button>
        </div>

        <table class="table table-striped">
            <thead>
            <tr>
                <th>
                    <input type="checkbox" id="selectAll"/>
                </th>
                <th>Username</th>
                <th>Email</th>
                <th>Status</th>
                <th>Last Login</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>
                        <input type="checkbox"
                               name="selectedIds"
                               value="@user.Id"
                               class="user-checkbox"/>
                    </td>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>@user.Status</td>
                    <td>@(user.LastLoginTime?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                </tr>
            }
            </tbody>
        </table>

    </form>

</div>
<script>
    function setAction(action) {
        document.getElementById("actionInput").value = action;
    }

    document.getElementById("selectAll").addEventListener("change", function () {
        document.querySelectorAll(".user-checkbox")
            .forEach(cb => cb.checked = this.checked);
    });
</script>