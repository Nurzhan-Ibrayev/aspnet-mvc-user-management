@model bool

<!DOCTYPE html>
<html>
<head>
    <title>Email Confirmation</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            margin-top: 100px;
        }
        .success {
            color: green;
        }
        .error {
            color: red;
        }
        .box {
            border: 1px solid #ddd;
            padding: 30px;
            display: inline-block;
            border-radius: 10px;
        }
    </style>
</head>
<body>
<div class="box">
    @if (Model)
    {
        <h2 class="success">✅ Email verified</h2>
        <p>Your account is now active.</p>
    }
    else
    {
        <h2 class="error">❌ Verification failed</h2>
        <p>Invalid or expired link.</p>
    }

    <a href="/Account/Login">Go to Login</a>
</div>
</body>
</html>